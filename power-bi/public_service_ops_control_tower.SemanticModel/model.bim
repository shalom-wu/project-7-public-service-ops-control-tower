            "formatString": "#,0",
            "summarizeBy": "none"
          },
          {
            "name": "rationale",
            "dataType": "string",
            "sourceColumn": "rationale",
            "summarizeBy": "none"
          }
        ],
        "partitions": [
          {
            "name": "dim_sla_targets",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Csv.Document(File.Contents(DataFolder & \"\\dim_sla_targets.csv\"),[Delimiter=\",\", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),",
                "    Promoted = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),",
                "    Typed = Table.TransformColumnTypes(Promoted, {{\"complaint_type\", type text}, {\"sla_days\", Int64.Type}, {\"rationale\", type text}})",
                "in",
                "    Typed"
              ]
            }
          }
        ]
      },
      {
        "name": "priority_scores",
        "columns": [
          {
            "name": "complaint_type",
            "dataType": "string",
            "sourceColumn": "complaint_type",
            "summarizeBy": "none"
          },
          {
            "name": "borough",
