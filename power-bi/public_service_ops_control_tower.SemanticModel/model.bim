{
  "name": "SemanticModel",
  "compatibilityLevel": 1567,
  "model": {
    "culture": "en-US",
    "defaultPowerBIDataSourceVersion": "powerBI_V3",
    "sourceQueryCulture": "en-US",
    "expressions": [
      {
        "name": "DataFolder",
        "kind": "m",
        "expression": [
          "\"C:\\Users\\shalo\\OneDrive\\Desktop\\project-7-public-service-ops-control-tower\\data\\powerbi\" meta [IsParameterQuery=true, Type=\"Text\", IsParameterQueryRequired=true]"
        ],
        "annotations": [
          {
            "name": "PBI_ResultType",
            "value": "Text"
          }
        ]
      }
    ],
    "tables": [
      {
        "name": "fact_service_requests",
        "columns": [
          {
            "name": "unique_key",
            "dataType": "string",
            "sourceColumn": "unique_key",
            "summarizeBy": "none"
          },
          {
            "name": "created_date",
            "dataType": "dateTime",
            "sourceColumn": "created_date",
            "summarizeBy": "none"
          },
          {
            "name": "closed_date",
            "dataType": "dateTime",
            "sourceColumn": "closed_date",
            "summarizeBy": "none"
          },
          {
            "name": "agency",
            "dataType": "string",
            "sourceColumn": "agency",
            "summarizeBy": "none"
          },
          {
            "name": "agency_name",
            "dataType": "string",
            "sourceColumn": "agency_name",
            "summarizeBy": "none"
          },
          {
            "name": "complaint_type",
            "dataType": "string",
            "sourceColumn": "complaint_type",
            "summarizeBy": "none"
          },
          {
            "name": "descriptor",
            "dataType": "string",
            "sourceColumn": "descriptor",
            "summarizeBy": "none"
          },
          {
            "name": "location_type",
            "dataType": "string",
            "sourceColumn": "location_type",
            "summarizeBy": "none"
          },
          {
            "name": "incident_zip",
            "dataType": "string",
            "sourceColumn": "incident_zip",
            "summarizeBy": "none"
          },
          {
            "name": "borough",
            "dataType": "string",
            "sourceColumn": "borough",
            "summarizeBy": "none"
          },
          {
            "name": "status",
            "dataType": "string",
            "sourceColumn": "status",
            "summarizeBy": "none"
          },
          {
            "name": "open_data_channel_type",
            "dataType": "string",
            "sourceColumn": "open_data_channel_type",
            "summarizeBy": "none"
          },
          {
            "name": "slice",
            "dataType": "string",
            "sourceColumn": "slice",
            "summarizeBy": "none"
          },
          {
            "name": "is_closed",
            "dataType": "boolean",
            "sourceColumn": "is_closed",
            "summarizeBy": "none"
          },
          {
            "name": "closure_days",
            "dataType": "double",
            "sourceColumn": "closure_days",
            "formatString": "0.0",
            "summarizeBy": "none"
          },
          {
            "name": "age_days",
            "dataType": "double",
            "sourceColumn": "age_days",
            "formatString": "#,0",
            "summarizeBy": "none"
          },
          {
            "name": "sla_days",
            "dataType": "int64",
            "sourceColumn": "sla_days",
            "formatString": "#,0",
            "summarizeBy": "none"
          },
          {
            "name": "sla_status",
            "dataType": "string",
            "sourceColumn": "sla_status",
            "summarizeBy": "none"
          },
          {
            "name": "aging_bucket",
            "dataType": "string",
            "sourceColumn": "aging_bucket",
            "summarizeBy": "none"
          },
          {
            "name": "created_week",
            "dataType": "dateTime",
            "sourceColumn": "created_week",
            "formatString": "yyyy-mm-dd",
            "summarizeBy": "none"
          },
          {
            "name": "created_month",
            "dataType": "dateTime",
            "sourceColumn": "created_month",
            "formatString": "mmm yyyy",
            "summarizeBy": "none"
          },
          {
            "name": "created_date_only",
            "dataType": "dateTime",
            "sourceColumn": "created_date_only",
            "formatString": "yyyy-mm-dd",
            "summarizeBy": "none"
          }
        ],
        "partitions": [
          {
            "name": "fact_service_requests",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Parquet.Document(File.Contents(DataFolder & \"\\fact_service_requests.parquet\")),",
                "    WithDateOnly = Table.AddColumn(Source, \"created_date_only\", each Date.From([created_date]), type date)",
                "in",
                "    WithDateOnly"
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "Total Requests",
            "expression": "COUNTROWS ( fact_service_requests )",
            "formatString": "#,0"
          },
          {
            "name": "Closed Requests",
            "expression": "CALCULATE ( [Total Requests], fact_service_requests[is_closed] = TRUE () )",
            "formatString": "#,0"
          },
          {
            "name": "Open Requests",
            "expression": "CALCULATE ( [Total Requests], fact_service_requests[is_closed] = FALSE () )",
            "formatString": "#,0"
          },
          {
            "name": "Closure Rate",
            "expression": "DIVIDE ( [Closed Requests], [Total Requests] )",
            "formatString": "0.0%"
          },
          {
            "name": "Backlog Count",
            "expression": "[Open Requests]",
            "formatString": "#,0"
          },
          {
            "name": "Average Closure Days",
            "expression": "AVERAGE ( fact_service_requests[closure_days] )",
            "formatString": "0.0"
          },
          {
            "name": "Median Closure Days",
            "expression": "MEDIAN ( fact_service_requests[closure_days] )",
            "formatString": "0.0"
          },
          {
            "name": "SLA Missed",
            "expression": "CALCULATE ( [Total Requests], fact_service_requests[sla_status] IN { \"Missed\", \"Open Past SLA\" } )",
            "formatString": "#,0"
          },
          {
            "name": "SLA Outcomes Known",
            "expression": "CALCULATE ( [Total Requests], fact_service_requests[sla_status] <> \"Open Within SLA\" )",
            "formatString": "#,0"
          },
          {
            "name": "SLA Miss Rate",
            "expression": "DIVIDE ( [SLA Missed], [SLA Outcomes Known] )",
            "formatString": "0.0%"
          },
          {
            "name": "Aging Backlog Count",
            "expression": "CALCULATE ( [Open Requests], fact_service_requests[aging_bucket] IN { \"31-90 days\", \"91-180 days\", \"180+ days\" } )",
            "formatString": "#,0"
          },
          {
            "name": "Aged Share of Backlog",
            "expression": "DIVIDE ( [Aging Backlog Count], [Open Requests] )",
            "formatString": "0.0%"
          },
          {
            "name": "Share of Total Requests",
            "expression": "DIVIDE ( [Total Requests], CALCULATE ( [Total Requests], ALLSELECTED ( fact_service_requests ) ) )",
            "formatString": "0.0%"
          },
          {
            "name": "Requests Previous Month",
            "expression": "CALCULATE ( [Total Requests], PREVIOUSMONTH ( dim_date[date] ) )",
            "formatString": "#,0"
          },
          {
            "name": "MoM Request Change %",
            "expression": "DIVIDE ( [Total Requests] - [Requests Previous Month], [Requests Previous Month] )",
            "formatString": "0.0%"
          }
        ]
      },
      {
        "name": "dim_date",
        "columns": [
          {
            "name": "date",
            "dataType": "dateTime",
            "sourceColumn": "date",
            "formatString": "yyyy-mm-dd",
            "summarizeBy": "none"
          },
          {
            "name": "week_start",
            "dataType": "dateTime",
            "sourceColumn": "week_start",
            "formatString": "yyyy-mm-dd",
            "summarizeBy": "none"
          },
          {
            "name": "month_start",
            "dataType": "dateTime",
            "sourceColumn": "month_start",
            "formatString": "mmm yyyy",
            "summarizeBy": "none"
          },
          {
            "name": "weekday",
            "dataType": "string",
            "sourceColumn": "weekday",
            "summarizeBy": "none"
          }
        ],
        "partitions": [
          {
            "name": "dim_date",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Csv.Document(File.Contents(DataFolder & \"\\dim_date.csv\"),[Delimiter=\",\", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),",
                "    Promoted = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),",
                "    Typed = Table.TransformColumnTypes(Promoted, {{\"date\", type date}, {\"week_start\", type date}, {\"month_start\", type date}, {\"weekday\", type text}})",
                "in",
                "    Typed"
              ]
            }
          }
        ]
      },
      {
        "name": "dim_sla_targets",
        "columns": [
          {
            "name": "complaint_type",
