      {
        "name": "W Volume",
        "columns": [
          {
            "name": "W Volume",
            "dataType": "double",
            "sourceColumn": "[W Volume]",
            "type": "calculatedTableColumn",
            "summarizeBy": "none",
            "extendedProperties": [
              {
                "name": "ParameterMetadata",
                "type": "json",
                "value": "{\"version\": 3, \"kind\": 2}"
              }
            ]
          }
        ],
        "partitions": [
          {
            "name": "W Volume",
            "mode": "import",
            "source": {
              "type": "calculated",
              "expression": "SELECTCOLUMNS ( GENERATESERIES ( 0, 1, 0.05 ), \"W Volume\", [Value] )"
            }
          }
        ],
        "measures": [
