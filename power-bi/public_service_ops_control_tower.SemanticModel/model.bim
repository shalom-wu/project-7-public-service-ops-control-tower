                "    Typed = Table.TransformColumnTypes(Promoted, {{\"created_week\", type date}, {\"requests_created\", Int64.Type}, {\"eventually_closed\", Int64.Type}, {\"still_open\", Int64.Type}, {\"avg_closure_days\", type number}, {\"sla_miss_rate\", type number}})",
