            "summarizeBy": "none"
          },
          {
            "name": "open_requests",
            "dataType": "int64",
            "sourceColumn": "open_requests",
            "formatString": "#,0",
            "summarizeBy": "none"
          },
          {
            "name": "sla_miss_rate",
            "dataType": "double",
            "sourceColumn": "sla_miss_rate",
            "formatString": "0.0%",
            "summarizeBy": "none"
          },
          {
            "name": "aged_share_of_open",
            "dataType": "double",
            "sourceColumn": "aged_share_of_open",
            "formatString": "0.0%",
            "summarizeBy": "none"
          },
          {
            "name": "volume_percentile",
            "dataType": "double",
            "sourceColumn": "volume_percentile",
            "formatString": "0.0%",
            "summarizeBy": "none"
          },
          {
            "name": "backlog_percentile",
            "dataType": "double",
            "sourceColumn": "backlog_percentile",
            "formatString": "0.0%",
            "summarizeBy": "none"
          },
          {
            "name": "priority_score",
            "dataType": "double",
            "sourceColumn": "priority_score",
            "formatString": "0.000",
            "summarizeBy": "none"
          },
          {
            "name": "priority_rank",
            "dataType": "int64",
            "sourceColumn": "priority_rank",
            "formatString": "0",
            "summarizeBy": "none"
          }
        ],
        "partitions": [
          {
            "name": "priority_scores",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Csv.Document(File.Contents(DataFolder & \"\\priority_scores.csv\"),[Delimiter=\",\", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),",
                "    Promoted = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),",
                "    Typed = Table.TransformColumnTypes(Promoted, {{\"complaint_type\", type text}, {\"borough\", type text}, {\"agency\", type text}, {\"total_requests\", Int64.Type}, {\"open_requests\", Int64.Type}, {\"sla_miss_rate\", type number}, {\"aged_share_of_open\", type number}, {\"volume_percentile\", type number}, {\"backlog_percentile\", type number}, {\"priority_score\", type number}, {\"priority_rank\", Int64.Type}})",
                "in",
                "    Typed"
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "Priority Score (Static)",
            "expression": "MAX ( priority_scores[priority_score] )",
            "formatString": "0.000"
          },
          {
            "name": "Dynamic Priority Score",
            "expression": "VAR w_vol  = [W Volume Value]\nVAR w_back = [W Backlog Value]\nVAR w_miss = [W Miss Value]\nVAR w_aged = [W Aged Value]\nVAR wsum   = w_vol + w_back + w_miss + w_aged\nRETURN\n    DIVIDE (\n          w_vol  * AVERAGE ( priority_scores[volume_percentile] )\n        + w_back * AVERAGE ( priority_scores[backlog_percentile] )\n        + w_miss * AVERAGE ( priority_scores[sla_miss_rate] )\n        + w_aged * AVERAGE ( priority_scores[aged_share_of_open] ),\n        wsum\n    )",
            "formatString": "0.000"
          },
          {
            "name": "Dynamic Priority Rank",
            "expression": "RANKX ( ALLSELECTED ( priority_scores ), [Dynamic Priority Score], , DESC, DENSE )",
            "formatString": "0"
          }
        ]
      },
